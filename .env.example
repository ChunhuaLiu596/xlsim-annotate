# Copy to .env.local for local dev; set the same keys in Vercel → Project → Settings → Environment Variables.
# The anon key is PUBLIC by design — security comes from the RLS policy in supabase/schema.sql.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Selects which cue-pair batch the assignment RPC serves: pilot or production.
VITE_ANNOTATION_BATCH=pilot

# From Prolific study setup → Study completion.
# Prefer the redirect URL ("I'll redirect them using a URL"); the code is a fallback.
VITE_PROLIFIC_COMPLETION_URL=https://app.prolific.com/submissions/complete?cc=XXXXXXX
VITE_PROLIFIC_COMPLETION_CODE=
